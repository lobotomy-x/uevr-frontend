<Window x:Class="UEVR.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:UEVR"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="13"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto"
        Background="#FF1A1B1C"
        FontFamily="{DynamicResource MaterialDesignFont}"
        mc:Ignorable="d"
        Title="UEVR"
        Closing="MainWindow_Closing" Loaded="MainWindow_Loaded"
        SizeToContent="WidthAndHeight" ResizeMode="CanMinimize" Icon="/UEVR2.png"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowDrop="True"
        Drop="MainWindow_Drop"  
        GotKeyboardFocus="MainWindow_GotKeyboardFocus"
        GotMouseCapture="MainWindow_GotMouseCapture"
        LostFocus="MainWindow_LostFocus"
        LostMouseCapture="MainWindow_LostMouseCapture"
        MouseLeftButtonDown="MainWindow_LeftButtonDown"
        MouseLeftButtonUp="MainWindow_LeftButtonUp"
        MouseMove="MainWindow_MouseMove"
        PreviewDragEnter="MainWindow_PreviewDragEnter"
        PreviewDragOver="MainWindow_PreviewDragOver"
        PreviewDrop="MainWindow_PreviewDrop" GotFocus="MainWindow_GotFocus" Activated="MainWindow_Activated" IsVisibleChanged="MainWindow_IsVisibleChanged" LayoutUpdated="MainWindow_LayoutUpdated"
        >
    <StackPanel x:Name="m_vertStackPanel" Orientation="Vertical">

        <Border MouseLeftButtonDown="TitleBar_MouseLeftButtonDown" Background="#FF1A1B1C" MouseMove="MainWindow_MouseMove">
            <Border.Style>
                <Style TargetType="{x:Type Border}">
                    <Setter Property="Cursor" Value="Hand"/>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Cursor" Value="SizeAll"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel Orientation="Horizontal" d:LayoutOverrides="TopPosition, BottomPosition" Width="500" HorizontalAlignment="Right">
                <DockPanel d:LayoutOverrides="TopPosition, BottomPosition" Height="30" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown" MouseLeftButtonUp="TitleBar_MouseLeftButtonUp">
                    <TextBlock Text="{Binding Title, RelativeSource={RelativeSource AncestorType={x:Type Window}, Mode=FindAncestor}}" FontWeight="Bold" Foreground="White" Background="{DynamicResource MaterialDesign.Brush.Chip.Background}" Width="355" HorizontalAlignment="Left" VerticalAlignment="Center" Padding="0,0,30,0" RenderTransformOrigin="0.5,0.5">
                        <TextBlock.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform/>
                                <SkewTransform/>
                                <RotateTransform/>
                                <TranslateTransform X="6"/>
                            </TransformGroup>
                        </TextBlock.RenderTransform>
                    </TextBlock>
                </DockPanel>
                <DockPanel x:Name="m_windowControlsDockPanel" Width="130" d:LayoutOverrides="TopPosition, BottomPosition" Height="30" HorizontalAlignment="Right">
                    <Button x:Name="m_closeMainWindowBtn"
Width="30" Style="{DynamicResource MaterialDesignFloatingActionMiniButton}" Height="30" HorizontalAlignment="Right" DockPanel.Dock="Right" Click="CloseButton_Click" BorderBrush="Transparent" Background="{x:Null}">
                        <materialDesign:PackIcon
    Width="30" Kind="Close" Height="30" HorizontalAlignment="Center"/>
                    </Button>
                    <Button x:Name="m_minimizeBtn"
Width="30" Style="{DynamicResource MaterialDesignFloatingActionMiniButton}" Height="30" HorizontalAlignment="Right" DockPanel.Dock="Right" Click="MinimizeButton_Click" BorderBrush="Transparent" Background="{x:Null}">
                        <materialDesign:PackIcon
    Width="30" Kind="Minimize" Height="30" HorizontalAlignment="Center"/>
                    </Button>
                    <DockPanel x:Name="settingsDockPanel"
Width="75" Margin="0,0,0,0" ForceCursor="True" Focusable="True" FlowDirection="RightToLeft" AllowDrop="True" Height="180">
                        <StackPanel
Width="118" Orientation="Horizontal" HorizontalAlignment="Left">
                            <ToggleButton
VerticalAlignment="Top" Width="35" ToolTip="Menu" Padding="0" x:Name="m_menuToggle" IsChecked="{Binding IsMenuOpen, Mode=TwoWay}" 
Height="30" Cursor="Hand" BorderThickness="0" Style="{DynamicResource MaterialDesignFlatButton}" Foreground="{x:Null}">
                                <materialDesign:PackIcon Width="25" Kind="HamburgerMenu" Height="25" Foreground="{DynamicResource MaterialDesignBody}"
VerticalContentAlignment="Center" d:IsLocked="True"/>
                            </ToggleButton>
                            <Popup x:Name="m_settingsMenuPopup" SnapsToDevicePixels="True" 
PlacementTarget="{Binding ElementName=m_menuToggle}" PopupAnimation="Fade" Placement="Bottom" IsOpen="{Binding IsMenuOpen, Mode=TwoWay}"
 Focusable="True" AllowsTransparency="True" StaysOpen="False" FlowDirection="LeftToRight" RenderTransformOrigin="1,1">
                                <Border
SnapsToDevicePixels="False" Padding="6" BorderThickness="1" BorderBrush="{DynamicResource MaterialDesign.Brush.Primary.Dark}">
                                    <local:MainWindowSettingsMenu x:Name="m_mainWindowSettingsMenu" 
DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType={x:Type Popup}}}" 
Focusable="True" IsTabStop="True" ForceCursor="True" Cursor="Hand"/>
                                </Border>
                            </Popup>
                        </StackPanel>
                    </DockPanel>
                </DockPanel>
            </StackPanel>
        </Border>
        <StackPanel x:Name="m_sideStackPanel" Orientation="Horizontal">
            <DockPanel MouseMove="MainWindow_MouseMove">
                <Menu DockPanel.Dock="Top" HorizontalAlignment="Center">
                    <Menu.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel Orientation="Vertical"/>
                        </ItemsPanelTemplate>
                    </Menu.ItemsPanel>
                    <MenuItem>
                        <MenuItem.Header>
                            <StackPanel Width="75">
                                <materialDesign:PackIcon Kind="QuestionMark" HorizontalAlignment="Center" Height="30" Width="30">
                                </materialDesign:PackIcon>
                            </StackPanel>
                        </MenuItem.Header>
                        <TextBlock TextWrapping="Wrap" Text="Author: praydog"/>

                        <MenuItem Header="_Documentation" Click="Documentation_Clicked">
                        </MenuItem>

                        <MenuItem Header="_Donate" Click="Donate_Clicked">
                        </MenuItem>
                    </MenuItem>
                    <MenuItem x:Name="m_openGlobalDirectoryBtn" Click="OpenGlobalDir_Clicked">
                        <MenuItem.Header>
                            <StackPanel Width="75">
                                <materialDesign:PackIcon Kind="Folder" HorizontalAlignment="Center" Height="30" Width="30">
                                </materialDesign:PackIcon>
                                <TextBlock Text="Open Global Dir" HorizontalAlignment="Center" FontSize="10"/>
                            </StackPanel>
                        </MenuItem.Header>
                    </MenuItem>
                    <MenuItem Visibility="Collapsed" x:Name="m_openProfileDirectoryBtn" Click="OpenProfileDir_Clicked">
                        <MenuItem.Header>
                            <StackPanel Width="75">
                                <materialDesign:PackIcon Kind="Folder" HorizontalAlignment="Center" Height="30" Width="30"/>
                                <TextBlock Text="Open Profile Dir" HorizontalAlignment="Center" FontSize="10"/>
                            </StackPanel>
                        </MenuItem.Header>
                    </MenuItem>
                    <MenuItem Visibility="Collapsed" x:Name="m_openGameDirectoryBtn" Click="OpenGameDir_Clicked">
                        <MenuItem.Header>
                            <StackPanel Width="75">
                                <materialDesign:PackIcon Kind="Folder" HorizontalAlignment="Center" Height="30" Width="30">
                                </materialDesign:PackIcon>
                                <TextBlock Text="Open Game Dir" HorizontalAlignment="Center" FontSize="10"/>
                            </StackPanel>
                        </MenuItem.Header>
                    </MenuItem>
                    <MenuItem Visibility="Visible" x:Name="m_exportConfigBtn" Click="ExportConfig_Clicked">
                        <MenuItem.Header>
                            <StackPanel Width="75">
                                <materialDesign:PackIcon Kind="Export"  HorizontalAlignment="Center" Height="30" Width="30" RenderTransformOrigin="0.5,0.5">
                                    <materialDesign:PackIcon.RenderTransform>
                                        <TransformGroup>
                                            <ScaleTransform/>
                                            <SkewTransform/>
                                            <RotateTransform Angle="180"/>
                                            <TranslateTransform/>
                                        </TransformGroup>
                                    </materialDesign:PackIcon.RenderTransform>
                                </materialDesign:PackIcon>
                                <TextBlock Text="Export Config" HorizontalAlignment="Center" FontSize="10"/>
                            </StackPanel>
                        </MenuItem.Header>
                    </MenuItem>
                    <MenuItem Visibility="Visible" x:Name="m_importConfigBtn" Click="ImportConfig_Clicked">
                        <MenuItem.Header>
                            <StackPanel Width="75">
                                <materialDesign:PackIcon Kind="Import"  HorizontalAlignment="Center" Height="30" Width="30" RenderTransformOrigin="0.5,0.5">
                                </materialDesign:PackIcon>
                                <TextBlock Text="Import Config" HorizontalAlignment="Center" FontSize="10"/>
                            </StackPanel>
                        </MenuItem.Header>
                    </MenuItem>
                </Menu>
                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom">
                    <TextBlock TextWrapping="Wrap" Text="Author: praydog"/>
                </StackPanel>
                <StackPanel DockPanel.Dock="Bottom" Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Bottom">
                    <Button Margin="5" Click="GitHub_Clicked" Background="Transparent" BorderThickness="0,0,0,0" RenderOptions.BitmapScalingMode="HighQuality" Height="40">
                        <Image Source="github.png" HorizontalAlignment="Center" Height="30" Width="30" />
                    </Button>
                    <Button Margin="5" Click="Donate_Clicked" Background="Transparent" BorderThickness="0,0,0,0" RenderOptions.BitmapScalingMode="HighQuality">
                        <Image Source="donate.png" HorizontalAlignment="Center" Height="30" Width="30" />
                    </Button>
                    <Button Margin="5" Click="Discord_Clicked" Background="Transparent" BorderThickness="0,0,0,0" RenderOptions.BitmapScalingMode="HighQuality">
                        <Image Source="discord.png" HorizontalAlignment="Center" Height="30" Width="30" />
                    </Button>
                </StackPanel>
            </DockPanel>
            <StackPanel x:Name="m_topStackPanel" Orientation="Vertical" MouseMove="MainWindow_MouseMove">
                <GroupBox x:Name="m_nNotificationsGroupBox" Header="Notifications" ClipToBounds="True" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock x:Name="m_adminExplanation" TextWrapping="Wrap" Text="Some executables may not show up or fail to inject unless started as Administrator." Visibility="Collapsed"/>
                        <TextBlock x:Name="m_updateStatus" TextWrapping="Wrap" Text="Update Complete." Visibility="Collapsed"/>
                        <Button x:Name="m_restartAsAdminButton" Content="Restart as Administrator" Click="RestartAsAdminButton_Click" Visibility="Collapsed"/>
                    </StackPanel>
                </GroupBox>
                <StackPanel Orientation="Horizontal">
                    <GroupBox Header="Inject" ClipToBounds="True" MouseMove="MainWindow_MouseMove">
                        <StackPanel ClipToBounds="True" HorizontalAlignment="Left">
                            <ComboBox x:Name="m_processListBox" DropDownOpened="ComboBox_DropDownOpened" SelectionChanged="ComboBox_SelectionChanged" VerticalAlignment="Top" MinWidth="500"/>
                            <Button x:Name="m_injectButton" Content="Inject" Click="Inject_Clicked"/>
                            <StackPanel Orientation="Horizontal">
                                <RadioButton x:Name="m_openvrRadio" Content="OpenVR"/>
                                <RadioButton x:Name="m_openxrRadio" Content="OpenXR"/>
                                <StackPanel Orientation="Horizontal">
                                    <ToggleButton x:Name="m_nullifyVRPluginsCheckbox" HorizontalAlignment="Left"/>
                                    <TextBlock TextWrapping="Wrap" Text="Nullify VR Plugins"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <ToggleButton x:Name="m_focusGameOnInjectionCheckbox" HorizontalAlignment="Left" IsChecked="True"/>
                                    <TextBlock TextWrapping="Wrap" Text="Focus game on injection"/>
                                </StackPanel>
                            </StackPanel>
                            <TextBlock x:Name="m_connectionStatus" TextWrapping="Wrap" Text="Unknown status"/>
                        </StackPanel>
                    </GroupBox>
                </StackPanel>
                <GroupBox Header="Game Settings" ClipToBounds="True" MouseMove="MainWindow_MouseMove">
                    <ListView x:Name="m_iniListView" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" MaxHeight="640">
                        <ListView.Resources>
                            <DataTemplate x:Key="ComboBoxTemplate">
                                <ComboBox ToolTip="{Binding Tooltip}" ItemsSource="{Binding ComboValues}" SelectedValuePath="Key" DisplayMemberPath="Value" SelectedValue="{Binding Value}" SelectionChanged="ComboChanged_Value"/>
                            </DataTemplate>
                            <DataTemplate x:Key="TextBoxTemplate">
                                <TextBox ToolTip="{Binding Tooltip}" Text="{Binding Value, Mode=TwoWay}" Width="150" TextChanged="TextChanged_Value"/>
                            </DataTemplate>
                            <DataTemplate x:Key="CheckBoxTemplate">
                                <CheckBox ToolTip="{Binding Tooltip}" IsChecked="{Binding ValueAsBool,Mode=TwoWay}" Width="150" Checked="CheckChanged_Value" Unchecked="CheckChanged_Value"/>
                            </DataTemplate>

                            <DataTemplate x:Key="KeyTemplate">
                                <TextBlock ToolTip="{Binding Tooltip}" Text="{Binding Key}"/>
                            </DataTemplate>

                            <local:ValueTemplateSelector x:Key="valueTemplateSelector"
                                     ComboBoxTemplate="{StaticResource ComboBoxTemplate}"
                                     TextBoxTemplate="{StaticResource TextBoxTemplate}"
                                     CheckboxTemplate="{StaticResource CheckBoxTemplate}"/>

                        </ListView.Resources>

                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Key" Width="200" CellTemplate="{StaticResource KeyTemplate}"/>
                                <GridViewColumn Header="Value" Width="150" CellTemplateSelector="{StaticResource valueTemplateSelector}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </GroupBox>
            </StackPanel>
        </StackPanel>
    </StackPanel>
</Window>
