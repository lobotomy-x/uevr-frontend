<UserControl
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d" x:Class="UEVR.MainWindowSettingsMenu"
             Foreground="{DynamicResource MaterialDesignBody}"
             FontFamily="{DynamicResource MaterialDesignFont}"
             Height="312" MinWidth="475"
             Loaded="UserControl_Loaded"
             Unloaded="UserControl_Unloaded" MaxWidth="475" BorderBrush="{DynamicResource MaterialDesignBody}" BorderThickness="1,16,1,1" Width="430" HorizontalContentAlignment="Left" MinHeight="330" MaxHeight="330" Background="{DynamicResource MaterialDesignChipBackground}">

    <WrapPanel HorizontalAlignment="Center" MaxWidth="475" MinWidth="450" SnapsToDevicePixels="True" VerticalAlignment="Center" ScrollViewer.VerticalScrollBarVisibility="Disabled" Width="438" >
        <Grid MinWidth="450" MaxWidth="450" Height="320" MinHeight="300" MaxHeight="330" Width="324">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="32*"/>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="0*"/>
                <ColumnDefinition Width="115*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="0*"/>
                <RowDefinition Height="120*"/>
                <RowDefinition Height="20*"/>
                <RowDefinition Height="60*"/>
                <RowDefinition Height="72*"/>
                <RowDefinition Height="0*"/>

            </Grid.RowDefinitions>
            <TabControl TabStripPlacement="Left" Style="{DynamicResource MaterialDesignTabControlBase}" SelectionChanged="TabControl_SelectionChanged" Grid.RowSpan="5" Grid.ColumnSpan="4" Margin="10,0,-14,0">
                <TabItem Header="Application" FontSize="13">
                    <StackPanel Margin="20,16">
                        <TextBlock
                            Text="VR Runtime Settings" Margin="0,0,0,8" FontSize="15" FontWeight="SemiBold" Width="300"/>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <RadioButton x:Name="m_openvrRadio" Content="OpenVR" GroupName="runtime" 
                                    Margin="12,0,16,0" IsChecked="{Binding OpenVRRadio, Mode=TwoWay}"/>
                                <RadioButton x:Name="m_openxrRadio" Content="OpenXR" GroupName="runtime" 
                                    IsChecked="{Binding OpenXRRadio, Mode=TwoWay}" Margin="0,0,0,0"/>
                            </StackPanel>
                            <Separator Height="4" Margin="0,4,0,0"/>
                            <CheckBox x:Name="m_ignoreVDWarningsCheckbox" Content="Ignore Virtual Desktop Warnings"  Padding="4,4,0,4" Margin="12,4,0,4" 
                                IsChecked="{Binding IgnoreFutureVDWarnings, Mode=TwoWay}"/>
                            <CheckBox x:Name="m_focusGameOnInjectionCheckbox" Content="Focus game window after injection" 
                           Padding="4,4,0,4"   Margin="12,0,0,0"   IsChecked="{Binding FocusGameOnInjection, Mode=TwoWay}"/>
                            <CheckBox x:Name="m_nullifyVRPluginsCheckbox" Padding="4,4,0,4" Content="Nullify VR Plugins" Margin="12,0,0,0" 
                                IsChecked="{Binding NullifyVRPlugins, Mode=TwoWay}"/>
                            <Separator Height="4" Margin="0,0,0,0"/>
                            <CheckBox x:Name="m_openToTrayCheckbox" Content="Open to System Tray"
                                      Margin="12,4,0,4" 
                                      IsChecked="{Binding OpenToTray, Mode=TwoWay}" Padding="4,4,0,4"/>
                            <CheckBox x:Name="m_directCloseCheckbox" Content="Close window instead of minimizing to tray"
                                      Margin="12,0,0,0" 
                                      IsChecked="{Binding CloseFromWindow, Mode=TwoWay}" Padding="4,4,0,4"/>
                            <Separator Height="4" Margin="0,4,0,4"/>
                            <CheckBox x:Name="m_startWithWindowsCheckbox" Content="Start with Windows" Checked="m_startWithWindowsCheckbox_Checked" 
                                      Margin="12,0,0,0" 
                                      Unchecked="m_startWithWindowsCheckbox_Unchecked" Padding="4,4,0,4"/>
                            <CheckBox x:Name="m_autoInjectCheckbox" Content="Automatic Injection" 
                                      Margin="12,0,0,0" IsChecked="{Binding AutomaticInjection, Mode=TwoWay}" Padding="4,4,0,4"/>
                            <CheckBox x:Name="m_autoUpdateCheckbox" Content="Automatic Nightly Updates" 
                            IsChecked="{Binding AutomaticNightlyUpdates, Mode=TwoWay}" Margin="12,0,0,0" Padding="4,4,0,4"/>
                        </StackPanel>
                    </StackPanel>
                </TabItem>

                <TabItem Header="Updates" FontSize="13">
                    <StackPanel Margin="20,16,20,0" MinHeight="300" MaxHeight="330" Height="300">
                        <TextBlock Text="Version Selector" FontSize="15" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,12" Width="300"/>
                        <TextBlock x:Name="DownloadStatusText" Text="Status: Ready" 
                            FontWeight="Medium" Margin="12,0,0,16" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                        <StackPanel Margin="0,0,0,8" Height="127">
                         
                            <TextBlock x:Name="CurrentVersion" Text="Current: Loading..." FontSize="13" 
                                Foreground="{DynamicResource MaterialDesignBodyLight}" Width="250" Height="36" Margin="4,4,4,4" HorizontalAlignment="Center"/>
                            <ComboBox x:Name="VersionDateCombo" Width="260" Height="40"
                                DisplayMemberPath="Published_At"
                                ItemStringFormat="{}{0:MMMM dd, yyyy}"
                                SelectionChanged="VersionDateCombo_SelectionChanged" Padding="4,4,4,4" UseLayoutRounding="True" ScrollViewer.CanContentScroll="True" FontSize="12" Background="{DynamicResource MaterialDesignPaper}" BorderBrush="{DynamicResource MaterialDesignDarkForeground}" Foreground="{DynamicResource MaterialDesignBody}" Margin="0,0,0,1" VerticalContentAlignment="Stretch"/>
                            <CheckBox x:Name="m_ignoreUpdatesCheckbox" Content="Ignore Updates" 
                                      Margin="24,12,12,0" IsChecked="{Binding AutomaticInjection, Mode=TwoWay}" Padding="4,4,0,4" Visibility="Visible" IsEnabled="False"/>

                        </StackPanel>
                        <Button x:Name="btnSelectVersion" Content="Download &amp; Install Selected Version" 
                            Click="btnSelectVersion_Click" Width="270" Height="40" Margin="0,0,0,8" IsEnabled="False"/>

                        <Button x:Name="btnOpenGithub" Content="View Release on GitHub" 
                            Click="btnOpenGithub_Click" Width="270" Height="40" IsEnabled="False"/>
                    </StackPanel>
                </TabItem>
                <TabItem Header="Launchers" FontSize="13">
                    <StackPanel
                        Margin="20,16">
                        <TextBlock
                            Text="Launcher Settings" Margin="0,0,0,8" FontSize="15" FontWeight="SemiBold" Width="300"/>
                        <TextBlock TextWrapping="Wrap" Margin="0,0,0,20" Foreground="{DynamicResource MaterialDesignBodyLight}" FontSize="11" Width="300"><Run Text="Force Epic Games Launcher and Steam to run in user-mode, enabling injection into most games without admin."/><LineBreak/><Run Text="Start with Windows will make this work automatically and override default startup"/></TextBlock>
                        <Button
                            Width="250" x:Name="m_launchSteamUnelevatedBtn" Margin="0,0,0,12" Height="40" Content="Launch Steam (User Mode)" Click="m_launchSteamUnelevatedClick"/>
                        <Button
                            Width="250" x:Name="m_launchEpicUnelevatedBtn" Margin="0,0,0,12" Height="40" Content="Launch EGS (User Mode)" Click="m_launchEpicUnelevatedClick"/>
                        <Separator
                            Margin="0,0,0,16"/>
                        <CheckBox
                            Unchecked="m_startSteamWithWindowsCheckbox_Unchecked" x:Name="m_startSteamWithWindowsCheckbox" Margin="12,0,0,12" Content="Start Steam with Windows (user mode)" Checked="m_startSteamWithWindowsCheckbox_Checked"/>
                        <CheckBox
                            Unchecked="m_startEpicWithWindowsCheckbox_Unchecked" 
                            x:Name="m_startEpicWithWindowsCheckbox" Content="Start Epic with Windows (user mode)"
                            Margin="12,0,0,12" Checked="m_startEpicWithWindowsCheckbox_Checked"/>
                    </StackPanel>
                </TabItem>


            </TabControl>
            <StackPanel Grid.RowSpan="3" Grid.Row="2" UseLayoutRounding="False" Margin="10,2,-10,10" Grid.ColumnSpan="3">
                <Button x:Name="m_checkUpdatesBtn" Content="Check Updates" Width="100" FontSize="12" Padding="0,4,0,4" Click="m_checkUpdatesBtn_Click" Margin="0,4,0,0" Height="24"/>
                <Button x:Name="m_resetAllBtn" Content="Reset All" Width="100" Margin="0,16,0,16" FontSize="12" Click="m_resetAllBtn_Click" Height="24"/>
                <Button x:Name="m_closeUEVRBtn" Content="Exit UEVR" Width="100" FontSize="12" Click="m_closeUEVRBtn_Click" Height="24" Margin="0,0,0,16"/>
                <Button x:Name="m_closeMenuBtn" Content="Close Menu" Width="100" FontSize="12" Click="m_closeMenuBtnClick" Height="24"/>
            </StackPanel>
        </Grid>
    </WrapPanel>
</UserControl>